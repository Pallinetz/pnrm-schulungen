# Anthropic API-Key für KI-Schulungsgenerierung (serverseitig via Vercel Function)
# Echten Key von https://console.anthropic.com/settings/keys holen
# Lokal: in .env eintragen | Produktion: in Vercel Dashboard unter Settings > Environment Variables
ANTHROPIC_KEY=sk-ant-api03-...

# Supabase-Projekt (Anon-Key ist öffentlich, landet im Browser-Bundle — NICHT der Service-Role-Key!)
# Werte im Supabase-Dashboard unter Project Settings > API
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGc...
